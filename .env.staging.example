APP_NAME="Dombi Staging"
APP_ENV=staging
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=https://staging.dombicenter.com

LOG_CHANNEL=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log

DOKU_CLIENT_ID=CHANGE_ME
DOKU_API_KEY=CHANGE_ME
DOKU_IS_SANDBOX=true
DOKU_CALLBACK_URL=https://staging.dombicenter.com/payment/doku/notify
DOKU_ENABLED_METHODS=qris,transfer,ewallet,credit_card

FCM_SERVER_KEY=
