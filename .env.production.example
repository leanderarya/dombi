APP_NAME=Dombi
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://app.dombicenter.com

LOG_CHANNEL=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@dombicenter.com
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@dombicenter.com"
MAIL_FROM_NAME="${APP_NAME}"

DOKU_CLIENT_ID=CHANGE_ME
DOKU_API_KEY=CHANGE_ME
DOKU_IS_SANDBOX=false
DOKU_CALLBACK_URL=https://app.dombicenter.com/payment/doku/notify
DOKU_ENABLED_METHODS=qris,transfer,ewallet,credit_card

FCM_SERVER_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dombi@example.com
